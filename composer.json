{
    "name": "clarion-app/llm-client",
    "description": "Handles interactions with Large Language Models",
    "type": "library",
    "repositories": [
        {
            "type": "path",
            "url": "../backend"
        }
    ],
    "require": {
        "clarion-app/eloquent-multichain-bridge": "dev-main",
        "clarion-app/http-queue": "dev-main",
        "php-webdriver/webdriver": "dev-main",
        "clarion-app/backend": "dev-main",
        "justinrainbow/json-schema": "^6.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "ClarionApp\\LlmClient\\": "src/",
            "ClarionApp\\LlmClient\\Database\\Factories\\": "database/factories/",
            "Database\\Factories\\": "database/factories/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0",
        "symfony/process": "^7.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Tim Schwartz",
            "email": "tim@metaverse.systems"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "ClarionApp\\LlmClient\\LlmClientServiceProvider"
            ]
        },
        "clarion": {
            "app-name": "@clarion-app/llm-client",
            "description": "Provides a client for interacting with Large Language Models"
        }
    },
    "minimum-stability": "dev",
    "scripts": {
        "test": "./vendor/bin/phpunit tests/ ${1:-}"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
